NODE_ENV=development
PORT=3001

# JWT Configuration
JWT_ACCESS_SECRET=access-secret-change-me-minimum-16-characters
JWT_REFRESH_SECRET=refresh-secret-change-me-minimum-16-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Redis Configuration
# If Redis runs in Docker and exposes 6379 to host, keep 127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false

# PostgreSQL Configuration
# External/local PostgreSQL (not managed by docker-compose in this project)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db
DB_LOGGING=false
