{
  "info": {
    "_postman_id": "9c84bd2e-c880-44a3-9f9b-fdc80f6b6436",
    "name": "Auth Service - Complete",
    "description": "Coleccion completa de pruebas para el microservicio AUTH (NestJS + Redis + Roles).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Login (Public)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Response has accessToken and refreshToken', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('adminAccessToken', json.accessToken);",
              "pm.environment.set('adminRefreshToken', json.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Refresh (Public)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{adminRefreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "refresh"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Response has rotated tokens', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('adminAccessToken', json.accessToken);",
              "pm.environment.set('adminRefreshToken', json.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - List All Users (ADMIN/MANAGER)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Response is array of users', function () {",
              "  pm.expect(Array.isArray(json)).to.be.true;",
              "  if (json.length > 0) {",
              "    pm.expect(json[0]).to.have.property('id');",
              "    pm.expect(json[0]).to.have.property('email');",
              "    pm.expect(json[0]).to.have.property('role');",
              "  }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Create User (ADMIN ONLY)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newmanager@example.com\",\n  \"password\": \"ManagerPass123!\",\n  \"role\": \"manager\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201 (Created)', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('User created with correct role', function () {",
              "  pm.expect(json.id).to.be.a('string').and.not.empty;",
              "  pm.expect(json.email).to.equal('newmanager@example.com');",
              "  pm.expect(json.role).to.equal('manager');",
              "});",
              "",
              "pm.environment.set('newUserEmail', 'newmanager@example.com');"
            ]
          }
        }
      ]
    },
