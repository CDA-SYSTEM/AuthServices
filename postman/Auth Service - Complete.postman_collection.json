    {
      "name": "08 - Test Forbidden: Create (NON-ADMIN)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"hackeruser@example.com\",\n  \"password\": \"Hacker123!\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 403 (Forbidden) - Only ADMIN can create', function () {",
              "  pm.response.to.have.status(403);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Error message indicates role requirement', function () {",
              "  pm.expect(json.message).to.include('admin') || pm.expect(json.message).to.include('403');",
              "});"
            ]
          }
        }
      ]
    },
