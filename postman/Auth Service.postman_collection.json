          }
        }
      ]
    },
    {
      "name": "03 - Validate Inspector Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{inspectorAccessToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/validate-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "validate-token"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Validate-token returns expected contract', function () {",
              "  pm.expect(json.valid).to.equal(true);",
              "  pm.expect(Array.isArray(json.roles)).to.be.true;",
              "  pm.expect(json.roles).to.include('inspector');",
              "  pm.expect(json.userId).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - NTC 5375 Access As Inspector (Allowed)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{inspectorAccessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/modules/ntc-5375/checklists",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "modules",
            "ntc-5375",
            "checklists"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Inspector can access NTC 5375 module', function () {",
              "  pm.expect(json.module).to.equal('ntc-5375-checklists');",
              "  pm.expect(json.access).to.equal(true);",
              "});"
            ]
          }
        }
      ]
    },
