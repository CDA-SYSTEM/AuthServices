{
  "info": {
    "_postman_id": "9c84bd2e-c880-44a3-9f9b-fdc80f6b6436",
    "name": "Auth Service - RBAC Functional",
    "description": "Coleccion minima para validacion funcional de RBAC y validate-token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Login Inspector",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{inspectorEmail}}\",\n  \"password\": \"{{inspectorPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Inspector receives tokens', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.collectionVariables.set('inspectorAccessToken', json.accessToken);",
              "pm.collectionVariables.set('inspectorRefreshToken', json.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Login Operario",
      "request": {
