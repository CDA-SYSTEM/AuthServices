    {
      "name": "03 - Register Inspector (ADMIN)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identificationType\": \"cc\",\n  \"identificationNumber\": \"{{inspectorIdentificationNumber}}\",\n  \"firstName\": \"Laura\",\n  \"lastName\": \"Inspectora\",\n  \"phoneNumber\": \"{{inspectorPhoneNumber}}\",\n  \"email\": \"{{inspectorEmail}}\",\n  \"password\": \"{{inspectorPassword}}\",\n  \"role\": \"inspector\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString();",
              "if (!pm.collectionVariables.get('inspectorIdentificationNumber')) {",
              "  pm.collectionVariables.set('inspectorIdentificationNumber', `11${suffix.slice(-8)}`);",
              "}",
              "if (!pm.collectionVariables.get('inspectorPhoneNumber')) {",
              "  pm.collectionVariables.set('inspectorPhoneNumber', `300${suffix.slice(-7)}`);",
              "}",
              "if (!pm.collectionVariables.get('inspectorEmail')) {",
              "  pm.collectionVariables.set('inspectorEmail', `inspector.${suffix}@example.com`);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Inspector created', function () {",
              "  pm.expect(json.id).to.be.a('string').and.not.empty;",
              "  pm.expect(json.role).to.equal('inspector');",
              "});",
              "pm.collectionVariables.set('inspectorId', json.id);"
            ]
          }
        }
      ]
    },
