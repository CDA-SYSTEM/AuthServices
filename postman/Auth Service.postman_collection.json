    {
      "name": "01 - Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Admin login returns tokens', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('adminAccessToken', json.accessToken);",
              "pm.collectionVariables.set('adminRefreshToken', json.refreshToken);"
            ]
          }
        }
      ]
    },
